IDP_BASE_URL=https://api.asgardeo.io/t/<ORG_NAME>
# EXPECTED_AUDIENCE is the client ID of the application whose tokens this server accepts.
# The agent obtains a token via client credentials using TRANSACTIONS_AGENT_ID/TRANSACTIONS_AGENT_SECRET.
# Asgardeo sets the `aud` claim to the agent application's client ID (TRANSACTIONS_AGENT_ID).
EXPECTED_AUDIENCE=<TRANSACTIONS_AGENT_ID>
# SSL_VERIFY=false   # only for self-signed certs in local dev
