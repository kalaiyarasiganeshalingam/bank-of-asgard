        <mxCell id="llmconfig" parent="1" style="shape=note;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;size=15;html=1;" value="&lt;b&gt;llm_config.yaml&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;provider: openai | gemini | anthropic&lt;br&gt;gateway.enabled: true | false&lt;/font&gt;" vertex="1">
