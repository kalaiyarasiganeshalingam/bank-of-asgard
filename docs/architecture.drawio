        <mxCell id="frontend" parent="1" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;html=1;" value="&lt;b&gt;React Frontend&lt;/b&gt;&lt;br&gt;&lt;i&gt;:5173 (Vite + React 19)&lt;/i&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;- Transactions Chat UI (WebSocket client)&lt;br&gt;- Auth, Profile, Signup Pages&lt;br&gt;- Identity Verification (Onfido SDK)&lt;br&gt;- AI Guardrails toggle&lt;/font&gt;" vertex="1">
          <mxGeometry height="105" width="310" x="255" y="185" as="geometry" />
        </mxCell>
        <mxCell id="backend" parent="1" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;html=1;" value="&lt;b&gt;Express Backend Server&lt;/b&gt;&lt;br&gt;&lt;i&gt;:3002 (Node.js)&lt;/i&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;- User &amp; Organization management&lt;br&gt;- Risk / Geolocation checks&lt;br&gt;- Transaction data provisioning&lt;br&gt;- SCIM2 orchestration&lt;/font&gt;" vertex="1">
          <mxGeometry height="110" width="280" x="55" y="410" as="geometry" />
        </mxCell>
        <mxCell id="agent" parent="1" style="rounded=1;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;html=1;" value="&lt;b&gt;Transactions Agent&lt;/b&gt;&lt;br&gt;&lt;i&gt;:8011 (FastAPI + LangChain)&lt;/i&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;- WebSocket chat server&lt;br&gt;- LangChain AI Agent + tool use&lt;br&gt;- OAuth2 PKCE flow (user consent popup)&lt;br&gt;- OBO token management (1h TTL cache)&lt;br&gt;- SecureLangChainTool (token hidden from LLM)&lt;br&gt;- AI Guardrails support (?secured=true)&lt;/font&gt;" vertex="1">
          <mxGeometry height="150" width="290" x="510" y="390" as="geometry" />
        </mxCell>
        <mxCell id="txapi" parent="1" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;html=1;" value="&lt;b&gt;Transactions API&lt;/b&gt;&lt;br&gt;&lt;i&gt;:8010 (FastAPI + Python)&lt;/i&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;- JWT / OBO token validation&lt;br&gt;- User-isolated transaction data (keyed by sub)&lt;br&gt;- Scopes: read_transactions, admin_provision&lt;br&gt;- In-memory transaction store&lt;/font&gt;" vertex="1">
